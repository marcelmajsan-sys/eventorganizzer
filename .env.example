# ============================================
# CRO Commerce Sponzorski Portal - .env.example
# ============================================

# --- Supabase: CRO Commerce 2026 (primarni projekt) ---
# Nađite u: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL_2026=https://your-2026-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_2026=your-2026-anon-key
SUPABASE_SERVICE_ROLE_KEY_2026=your-2026-service-role-key

# --- Supabase: CRO Commerce 2025 ---
NEXT_PUBLIC_SUPABASE_URL_2025=https://your-2025-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY_2025=your-2025-anon-key
SUPABASE_SERVICE_ROLE_KEY_2025=your-2025-service-role-key

# --- Supabase: Fallback (koristi se ako _2026/_2025 varijable nisu postavljene) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Resend (Email) ---
# Registrirajte se na resend.com, kreirajte API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- App URL ---
# Lokalno: http://localhost:3000
# Produkcija: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Admin email (prima obavijesti o kašnjenjima) ---
ADMIN_EMAIL=tim@cro-commerce.hr

# --- Vercel Cron Secret ---
# Generirajte jaki random string, npr: openssl rand -base64 32
CRON_SECRET=your-very-secret-cron-key-here
